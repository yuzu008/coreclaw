# CoreClaw Environment Configuration
# Copy to .env and fill in your values.

# --- Required ---
# GitHub token for Copilot CLI authentication
GITHUB_TOKEN=

# --- Assistant ---
ASSISTANT_NAME=Andy

# --- Optional ---
# Container image (default: coreclaw-agent:latest)
# CONTAINER_IMAGE=coreclaw-agent:latest

# Container timeout in ms (default: 1800000 = 30 min)
# CONTAINER_TIMEOUT=1800000

# Max concurrent containers (default: 5)
# MAX_CONCURRENT_CONTAINERS=5

# Credential proxy port (default: 3001)
# CREDENTIAL_PROXY_PORT=3001

# Idle timeout in ms (default: 1800000 = 30 min)
# IDLE_TIMEOUT=1800000

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
